<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/navigation_activity">

    <fragment
        android:id="@id/navigation_home"
        android:name="com.alaka_ala.florafilm.ui.fragments.home.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home" >
        <action
            android:id="@+id/action_navigation_home_to_filmDetailsFragment"
            app:destination="@id/filmDetailsFragment" />
    </fragment>

    <fragment
        android:id="@id/navigation_activity"
        android:name="com.alaka_ala.florafilm.ui.fragments.activity.ActivityFragment"
        android:label="Activity"
        tools:layout="@layout/fragment_activity" />

    <fragment
        android:id="@id/navigation_menu"
        android:name="com.alaka_ala.florafilm.ui.fragments.menu.MenuFragment"
        android:label="Menu"
        tools:layout="@layout/fragment_menu" />
    <dialog
        android:id="@+id/filmDetailsFragment"
        android:name="com.alaka_ala.florafilm.ui.fragments.filmDetails.FilmDetailsFragment"
        android:label="fragment_film_details"
        tools:layout="@layout/fragment_film_details" />

</navigation>